package com.dams.report;

import com.aventstack.extentreports.ExtentReports;
import com.aventstack.extentreports.ExtentTest;
import com.aventstack.extentreports.Status;
import com.aventstack.extentreports.reporter.ExtentSparkReporter;
import com.aventstack.extentreports.reporter.configuration.Theme;
import com.dams.core.Config;

import java.io.File;
import java.text.SimpleDateFormat;
import java.util.Date;

/**
 * ReportManager.java — HTML Test Report Generator
 *
 * RESPONSIBILITY:
 *   This class manages the full lifecycle of the ExtentReports HTML report:
 *   1. initialise()   — called once in @BeforeSuite  — sets up the HTML file
 *   2. createTest()   — called when a test starts    — adds a test entry
 *   3. logStep()      — called inside test steps     — logs pass/fail/info per step
 *   4. flush()        — called once in @AfterSuite   — writes everything to disk
 *
 *   It does NOT control browsers, NOT take screenshots, NOT read config directly
 *   (only for report path and system info).
 *
 * EXTENTREPORTS CONCEPTS:
 *
 *   ExtentReports      — the "engine" that collects all test results in memory
 *   ExtentSparkReporter — the "renderer" that converts results to a styled HTML file
 *   ExtentTest         — one test entry in the report (has steps inside it)
 *   Status             — PASS, FAIL, SKIP, INFO, WARNING
 *
 * THREAD-SAFETY:
 *   ThreadLocal<ExtentTest> ensures each parallel test thread writes to its
 *   own test entry — results never get mixed up across threads.
 */
public class ReportManager {

    // The main report engine — one shared instance for the whole suite
    private static ExtentReports extent;

    // One ExtentTest entry per thread — keeps parallel tests isolated
    private static final ThreadLocal<ExtentTest> testHolder = new ThreadLocal<>();

    // Utility class — no instances needed
    private ReportManager() {}

    // ── Report Lifecycle ────────────────────────────────────────────────────

    /**
     * STEP 1 — Called in @BeforeSuite.
     * Sets up the HTML report file path, theme, and system information.
     * Must be called before any tests start.
     */
    public static synchronized void initialise() {
        Config config = Config.getInstance();

        // Build timestamped report file name so each run creates a new file
        String timestamp  = new SimpleDateFormat("yyyy-MM-dd_HH-mm-ss").format(new Date());
        String reportDir  = config.getReportDir();
        String reportPath = reportDir + File.separator + "DAMS_Report_" + timestamp + ".html";

        // Create the report directory if it doesn't exist
        new File(reportDir).mkdirs();

        // ── ExtentSparkReporter: controls what the HTML file looks like ──
        ExtentSparkReporter spark = new ExtentSparkReporter(reportPath);
        spark.config().setDocumentTitle("DAMS Admin Panel — Automation Report");
        spark.config().setReportName("Login & OTP Test Execution");
        spark.config().setTheme(Theme.DARK);          // Dark theme — easy on the eyes
        spark.config().setEncoding("UTF-8");
        spark.config().setTimeStampFormat("dd MMM yyyy HH:mm:ss");

        // ── ExtentReports: the main engine — attach the renderer ──
        extent = new ExtentReports();
        extent.attachReporter(spark);

        // System info panel shown at the top of the HTML report
        extent.setSystemInfo("Application", "DAMS Admin Panel");
        extent.setSystemInfo("URL",         config.getBaseUrl());
        extent.setSystemInfo("Browser",     config.getBrowser());
        extent.setSystemInfo("Environment", config.getEnvironment());
        extent.setSystemInfo("OS",          System.getProperty("os.name"));
        extent.setSystemInfo("Java",        System.getProperty("java.version"));
        extent.setSystemInfo("Executed By", System.getProperty("user.name", "CI/CD"));

        System.out.println("[ReportManager] Report initialised: " + reportPath);
    }

    /**
     * STEP 2 — Called when a test method starts (in ExtentTestListener or BaseTest).
     * Creates a new test node in the report for this test.
     *
     * @param testName   Display name shown in the report for this test
     * @param description Short description of what this test verifies
     */
    public static void createTest(String testName, String description) {
        ExtentTest test = extent.createTest(testName, description);
        testHolder.set(test);
        System.out.println("[ReportManager] Test created: " + testName);
    }

    // ── Step Logging ────────────────────────────────────────────────────────

    /**
     * Logs a single step with PASS status (green).
     * Use this for each action that succeeds: "Entered email", "Clicked Login" etc.
     */
    public static void logPass(String stepDescription) {
        getTest().log(Status.PASS, stepDescription);
    }

    /**
     * Logs a single step with FAIL status (red).
     * Use this when an assertion fails or an exception is caught.
     */
    public static void logFail(String stepDescription) {
        getTest().log(Status.FAIL, stepDescription);
    }

    /**
     * Logs a single step with INFO status (blue).
     * Use this for informational messages: "Navigating to URL", "OTP entered" etc.
     */
    public static void logInfo(String stepDescription) {
        getTest().log(Status.INFO, stepDescription);
    }

    /**
     * Attaches a failure screenshot to the current test entry in the report.
     * The screenshot appears as an inline image in the HTML report.
     *
     * @param screenshotPath  Absolute path to the PNG file
     */
    public static void attachScreenshot(String screenshotPath) {
        if (screenshotPath != null) {
            try {
                getTest().addScreenCaptureFromPath(screenshotPath, "Failure Screenshot");
                System.out.println("[ReportManager] Screenshot attached to report.");
            } catch (Exception e) {
                System.out.println("[ReportManager] Could not attach screenshot: " + e.getMessage());
            }
        }
    }

    /**
     * Marks the current test as FAILED with the exception message and attaches screenshot.
     * Convenience method used by the TestNG listener on test failure.
     */
    public static void markFail(Throwable throwable, String screenshotPath) {
        getTest().log(Status.FAIL, "Test FAILED: " + throwable.getMessage());
        attachScreenshot(screenshotPath);
    }

    /**
     * STEP 4 — Called in @AfterSuite.
     * Writes all in-memory results to the HTML file on disk.
     * Without flush(), the HTML file stays empty/incomplete.
     */
    public static void flush() {
        if (extent != null) {
            extent.flush();
            System.out.println("[ReportManager] Report flushed to disk.");
        }
    }

    // ── Internal helpers ────────────────────────────────────────────────────

    /**
     * Returns the ExtentTest for the current thread.
     * Throws a clear error if createTest() was never called — avoids NullPointerException.
     */
    private static ExtentTest getTest() {
        ExtentTest test = testHolder.get();
        if (test == null) {
            throw new IllegalStateException(
                "[ReportManager] No ExtentTest found for current thread. " +
                "Did you call ReportManager.createTest() before logging steps?");
        }
        return test;
    }
}

