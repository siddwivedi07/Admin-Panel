<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
  testng.xml  —  DAMS Delhi Test Suite
  Isme define hota hai: kaunsi test classes run hongi, order, groups.
  mvn clean test → isi file ko follow karta hai.
-->
<suite name="DAMS Admin Panel — Full Test Suite" verbose="2" parallel="none">

    <listeners>
        <!-- TestNG built-in listener — console output improve karta hai -->
        <listener class-name="org.testng.reporters.SuiteHTMLReporter"/>
    </listeners>

    <test name="DAMS Login Tests">
        <classes>
            <class name="com.dams.test.LoginTest"/>
        </classes>
    </test>

</suite>
